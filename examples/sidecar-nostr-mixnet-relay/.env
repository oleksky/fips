# FIPS sidecar default configuration.
# Override these values or create a .env.local file.

# Node identity — generate with: fipsctl keygen
# Must be set before running: export FIPS_NSEC=<your-nsec>
FIPS_NSEC=

# Peer configuration (leave empty for standalone operation)
FIPS_PEER_NPUB=npub1qmc3cvfz0yu2hx96nq3gp55zdan2qclealn7xshgr448d3nh6lks7zel98
FIPS_PEER_ADDR=217.77.8.91:2121
FIPS_PEER_ALIAS=vps
# Transport: udp | tcp | nym
# This single switch also gates the nym-socks5-client sidecar via
# COMPOSE_PROFILES below — `nym` here starts it; anything else doesn't.
FIPS_PEER_TRANSPORT=udp

# Activate the `nym` compose profile when (and only when) the peer
# transport is nym. Compose interpolates this in .env (>= v2.24).
COMPOSE_PROFILES=${FIPS_PEER_TRANSPORT}

# ----- Nym mixnet sidecar (only used when FIPS_PEER_TRANSPORT=nym) -----
# Required: a Nym network-requester service provider address.
# Find one at: https://harbourmaster.nymtech.net/  (or run your own)
NYM_SERVICE_PROVIDER=
NYM_CLIENT_ID=fips-nym-client
NYM_SOCKS5_PORT=1080
NYM_SOCKS5_BIND=0.0.0.0
FIPS_NYM_SOCKS5_ADDR=127.0.0.1:1080

# Logging
RUST_LOG=info
